{
  "name": "relaxason",
  "version": "1.0.2",
  "description": "Shop window for the relaxason website",
  "private": true,
  "packageManager": "yarn@4.13.0",
  "devDependencies": {
    "@netlify/functions": "^5.1.2",
    "@types/node": "^22.19.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "terser": "^5.46.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "dependencies": {
    "@fontsource/josefin-sans": "^5.2.8",
    "@fontsource/lora": "^5.2.8",
    "@fontsource/source-sans-3": "^5.2.9",
    "@getbrevo/brevo": "^4.0.1",
    "@mantine/core": "^8.3.16",
    "@mantine/form": "^8.3.16",
    "@mantine/hooks": "^8.3.16",
    "@tabler/icons-react": "^3.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.1"
  },
  "scripts": {
    "build": "vite build",
    "build:functions": "tsc -p tsconfig.functions.json",
    "netlify:build": "yarn build && yarn build:functions",
    "netlify:dev": "netlify dev",
    "docker:build": "docker build --no-cache -t relaxason:$npm_package_version .",
    "check": "echo '[check] Running compilation...'; tsc --noEmit && echo '[check] Compilation succeeded without errors.' && exit 0 || echo '[check] Compilation failed, please check.' && exit 1",
    "clean": "rimraf */(dist|lib|coverage|node_modules)",
    "compile": "tsc",
    "preview": "vite preview",
    "start": "yarn netlify:dev"
  }
}
